# @plugin(@varlock/google-secret-manager-plugin)
# @initGsm(projectId=demo-vibe-coding)
# ---
# Public config — safe for frontend build (VITE_ prefix)
VITE_FIREBASE_PROJECT_ID=string
VITE_FIREBASE_API_KEY=string
VITE_FIREBASE_AUTH_DOMAIN=string
VITE_USE_EMULATORS=boolean

# Emulator overrides (local Docker — literals, not GSM)
# VITE_FIREBASE_AUTH_DOMAIN=localhost

# Server-only — resolved from GSM in deployed environments
# FIREBASE_PROJECT_ID=gsm()
# SLACK_AUTH_TOKEN=gsm()
